{
  "cesp_version": "1.0",
  "name": "stronghold-wolf",
  "display_name": "The Wolf (Stronghold Crusader)",
  "version": "1.0.0",
  "author": { "name": "Marko Jevic", "github": "koyev" },
  "license": "fair-use",
  "language": "en",
  "categories": {
    "session.start": {
      "sounds": [
        { "file": "sounds/wf_add_player.wav", "label": "Growling" }
      ]
    },
    "task.acknowledge": {
      "sounds": [
        { "file": "sounds/wf_taunt_05.wav", "label": "Men approach" },
        { "file": "sounds/wf_taunt_03.wav", "label": "Intend to repay that debt" }
      ]
    },
    "task.complete": {
      "sounds": [
        { "file": "sounds/wf_vict_01.wav", "label": "I win, you lose" },
        { "file": "sounds/wf_vict_04.wav", "label": "Great pleasure to announce you're finished" },
        { "file": "sounds/wf_vict_02.wav", "label": "Weak and unfit to command" }
      ]
    },
    "task.error": {
      "sounds": [
        { "file": "sounds/wf_anger_01.wav", "label": "You will pay dearly" },
        { "file": "sounds/wf_anger_02.wav", "label": "Damn you, I will have revenge" }
      ]
    },
    "input.required": {
      "sounds": [
        { "file": "sounds/wf_plead_03.wav", "label": "Underestimated you a little" },
        { "file": "sounds/wf_plead_04.wav", "label": "You fight better than your father" }
      ]
    },
    "resource.limit": {
      "sounds": [
        { "file": "sounds/wf_plead_02.wav", "label": "I shall return" },
        { "file": "sounds/wf_anger_03.wav", "label": "You will feel my bite" }
      ]
    },
    "user.spam": {
      "sounds": [
        { "file": "sounds/wf_anger_04.wav", "label": "Rid me of your presence" },
        { "file": "sounds/wf_taunt_08.wav", "label": "No match for me, boy" },
        { "file": "sounds/wf_kick_player.wav", "label": "Screaming" }
      ]
    }
  }
}
